.page { background: #f7f9f5; min-height: 100vh; padding-bottom: 40rpx; }

/* Header */
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 32rpx; background: #fff; border-bottom: 2rpx solid #f0f0f0;
}
.header-title { font-size: 32rpx; font-weight: 700; color: #262626; }
.back-btn { font-size: 26rpx; color: #52c41a; padding: 8rpx 20rpx;
  background: #f6ffed; border-radius: 20rpx; border: 2rpx solid #b7eb8f; }

/* Profile card */
.profile-card {
  background: #fff; margin: 20rpx 24rpx; border-radius: 24rpx;
  padding: 24rpx; display: flex; align-items: center; gap: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.avatar {
  width: 88rpx; height: 88rpx; background: linear-gradient(135deg, #bae637, #52c41a);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
}
.avatar-emoji { font-size: 44rpx; }
.profile-info { flex: 1; }
.profile-name  { display: block; font-size: 32rpx; font-weight: 700; color: #262626; }
.profile-grade { display: block; font-size: 24rpx; color: #8c8c8c; margin-top: 4rpx; }
.profile-status { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.status-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.dot-green { background: #52c41a; box-shadow: 0 0 8rpx rgba(82,196,26,0.5); }
.dot-gray  { background: #d9d9d9; }
.status-label { font-size: 26rpx; font-weight: 600; color: #52c41a; }
.status-round  { font-size: 22rpx; color: #8c8c8c; }

/* Section header */
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 28rpx 10rpx; font-size: 28rpx; font-weight: 600; color: #262626;
}
.see-all { font-size: 24rpx; color: #52c41a; font-weight: 400; }
.week-avg-badge { font-size: 24rpx; color: #8c8c8c; }

/* Stats grid */
.stats-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx; margin: 0 24rpx 8rpx;
}
.stat-card {
  background: #fff; border-radius: 20rpx; padding: 20rpx 16rpx;
  display: flex; flex-direction: column; align-items: flex-start; gap: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.stat-icon  { font-size: 34rpx; }
.stat-val   { font-size: 40rpx; font-weight: 700; color: #262626; line-height: 1.1; }
.stat-name  { font-size: 22rpx; color: #8c8c8c; }
.stat-target{ font-size: 20rpx; color: #bfbfbf; }
.green  { color: #52c41a; }
.orange { color: #fa8c16; }
.red    { color: #ff4d4f; }
.bold   { font-weight: 600; }

/* Events */
.events-card {
  background: #fff; border-radius: 20rpx; margin: 0 24rpx 8rpx;
  padding: 8rpx 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.empty-tip { text-align: center; font-size: 26rpx; color: #bfbfbf; padding: 32rpx 0; }
.event-row {
  display: flex; align-items: center; gap: 16rpx;
  padding: 18rpx 0; border-bottom: 2rpx solid #f5f5f5;
}
.event-row:last-child { border-bottom: none; }
.ev-dot  { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.ev-time { font-size: 24rpx; color: #8c8c8c; width: 90rpx; flex-shrink: 0; }
.ev-label{ font-size: 26rpx; color: #262626; flex: 1; }

/* Weekly chart */
.chart-card {
  background: #fff; border-radius: 20rpx; margin: 0 24rpx 8rpx;
  padding: 24rpx 16rpx 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.chart-bars {
  display: flex; align-items: flex-end; justify-content: space-between;
  height: 180rpx; gap: 8rpx;
}
.chart-col {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: flex-end; height: 100%;
}
.bar-label-top { font-size: 18rpx; color: #8c8c8c; height: 30rpx; text-align: center; }
.bar-track {
  flex: 1; width: 100%; display: flex; align-items: flex-end;
  background: #f5f5f5; border-radius: 8rpx; overflow: hidden;
}
.bar-fill { width: 100%; border-radius: 8rpx; min-height: 6rpx; transition: height 0.3s; }
.bar-day  { font-size: 22rpx; color: #8c8c8c; margin-top: 8rpx; }

/* Privacy row */
.privacy-row {
  background: #fff; border-radius: 20rpx; margin: 0 24rpx 20rpx;
  padding: 12rpx 16rpx; display: flex; justify-content: space-around;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.privacy-item {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 12rpx 8rpx;
}
.privacy-icon  { font-size: 40rpx; }
.privacy-title { font-size: 22rpx; color: #262626; font-weight: 500; text-align: center; }
.privacy-sub   { font-size: 20rpx; color: #52c41a; text-align: center; }

/* Offline */
.offline-bar {
  text-align: center; font-size: 24rpx; color: #ff4d4f;
  padding: 16rpx; background: #fff1f0; margin: 0 24rpx;
  border-radius: 12rpx; border: 2rpx solid #ffa39e;
}

/* Camera preview */
.cam-wrap {
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #000;
  height: 340rpx;
}
.cam-img { width: 100%; height: 340rpx; display: block; }
.cam-badge {
  position: absolute; top: 16rpx; left: 16rpx;
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(0,0,0,0.5); border-radius: 20rpx; padding: 6rpx 16rpx;
}
.cam-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%; background: #ff4d4f;
  animation: blink 1.2s infinite;
}
.cam-lbl { font-size: 20rpx; color: #fff; font-weight: 600; letter-spacing: 2rpx; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }

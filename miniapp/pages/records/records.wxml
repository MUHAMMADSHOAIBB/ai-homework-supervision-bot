<view class="page">
  <view class="header"><text class="header-title">{{i_title}}</text></view>

  <view class="session-list" wx:if="{{sessions.length}}">
    <view wx:for="{{sessions}}" wx:key="id" class="session-card">
      <view class="session-top">
        <text class="session-date">{{item.dateStr}}</text>
        <view class="score-badge" style="background:{{item.scoreColor}}20;color:{{item.scoreColor}}">
          <text>{{item.score}}</text>
        </view>
      </view>
      <view class="session-stats">
        <view class="mini-stat">
          <text class="ms-val green">{{item.focusTime}}</text>
          <text class="ms-lbl">{{i_focusTime}}</text>
        </view>
        <view class="mini-stat">
          <text class="ms-val">{{item.rounds}}</text>
          <text class="ms-lbl">{{i_rounds}}</text>
        </view>
        <view class="mini-stat">
          <text class="ms-val orange">{{item.distracts}}</text>
          <text class="ms-lbl">{{i_distracts}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!sessions.length}}">
    <text class="empty-icon">📚</text>
    <text class="empty-title">{{i_noRecords}}</text>
    <text class="empty-sub">{{i_noRecordsSub}}</text>
  </view>
</view>

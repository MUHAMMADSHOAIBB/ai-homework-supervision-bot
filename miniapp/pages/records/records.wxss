.page { background: #f7f9f5; min-height: 100vh; padding-bottom: 120rpx; }
.header { padding: 20rpx 32rpx; background: #fff; border-bottom: 2rpx solid #f0f0f0; }
.header-title { font-size: 34rpx; font-weight: 700; }
.session-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.session-card { background: #fff; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.session-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.session-date { font-size: 28rpx; font-weight: 600; color: #262626; }
.score-badge { font-size: 24rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 20rpx; }
.session-stats { display: flex; justify-content: space-around; }
.mini-stat { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.ms-val { font-size: 32rpx; font-weight: 700; color: #262626; }
.ms-lbl { font-size: 22rpx; color: #8c8c8c; }
.green  { color: #52c41a; } .orange { color: #fa8c16; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 40rpx; gap: 16rpx; }
.empty-icon  { font-size: 80rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #595959; }
.empty-sub   { font-size: 24rpx; color: #bfbfbf; text-align: center; }

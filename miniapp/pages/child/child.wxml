<view class="page">

  <!-- ── Header ── -->
  <view class="header">
    <view class="header-left">
      <text class="header-logo">🌱</text>
      <text class="header-title">监督 Bot</text>
    </view>
    <view class="header-right">
      <view class="mute-btn {{laptopMuted ? 'mute-btn-on' : ''}}" bindtap="toggleLaptopMute">
        <text class="mute-icon">{{laptopMuted ? '🔇' : '🔊'}}</text>
        <text class="mute-lbl">{{laptopMuted ? 'Muted' : 'PC Voice'}}</text>
      </view>
      <view class="parent-btn" bindtap="goToParent">
        <text>{{i_parentBtn}}</text>
      </view>
    </view>
  </view>

  <!-- ── Robot + Speech bubble ── -->
  <view class="robot-section">
    <view class="robot-wrap">
      <view class="robot-body">
        <view class="robot-antenna"></view>
        <view class="robot-head">
          <view class="robot-eyes">
            <view class="eye"></view>
            <view class="eye"></view>
          </view>
          <view class="robot-mouth"></view>
        </view>
        <view class="robot-feet">
          <view class="foot"></view>
          <view class="foot"></view>
        </view>
      </view>
    </view>
    <view class="speech-bubble">
      <text class="speech-text">{{aiMessage}}</text>
    </view>
  </view>

  <!-- ── Stop speaking bar ── -->
  <view class="speak-stop-bar" wx:if="{{isSpeaking}}" bindtap="stopSpeak">
    <text class="speak-stop-bar-text">🔇  Tap to stop speaking</text>
  </view>

  <!-- ── Camera preview ── -->
  <view class="cam-wrap" wx:if="{{showCamera && connected}}">
    <image class="cam-img" src="{{frameUrl}}" mode="aspectFill" show-menu-by-longpress="{{false}}"/>
    <view class="cam-badge">
      <view class="cam-dot"></view>
      <text class="cam-lbl">LIVE</text>
    </view>
  </view>

  <!-- ── Timer card ── -->
  <view class="timer-card">
    <view class="timer-top">
      <text class="phase-tag">🍅 {{stateLabel}} · {{roundNumber}}/{{totalRounds}}</text>
      <view class="skip-btn" wx:if="{{sessionActive}}">{{i_skipBtn}}</view>
    </view>

    <view class="timer-center">
      <canvas canvas-id="timerRing"
              class="timer-canvas"
              style="width:240rpx;height:240rpx;position:absolute;top:0;left:50%;margin-left:-120rpx;">
      </canvas>
      <view class="timer-text-wrap">
        <text class="time-big">{{timeDisplay}}</text>
        <view class="time-goal-pill">
          <text>{{i_goal}}</text>
        </view>
      </view>
    </view>

    <!-- Phase steps -->
    <view class="phase-row">
      <view wx:for="{{phases}}" wx:key="id"
            class="phase-item {{item.active ? 'phase-active' : ''}} {{item.done ? 'phase-done' : ''}}">
        <view class="phase-icon-wrap">
          <text class="phase-icon">{{item.icon}}</text>
        </view>
        <text class="phase-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- ── Alert card ── -->
  <view class="alert-card" wx:if="{{showAlert}}">
    <text class="alert-bell">🔔</text>
    <view class="alert-body">
      <text class="alert-title">{{i_alertTitle}}</text>
      <text class="alert-msg">{{currentAlert}}</text>
    </view>
    <view class="alert-ok" bindtap="dismissAlert">{{i_alertOk}}</view>
  </view>

  <!-- ── Score badge (when active) ── -->
  <view class="score-row" wx:if="{{sessionActive}}">
    <view class="score-item">
      <text class="score-val green">{{focusScore}}</text>
      <text class="score-lbl">{{i_lbl1}}</text>
    </view>
    <view class="score-divider"></view>
    <view class="score-item">
      <text class="score-val">{{roundNumber}}</text>
      <text class="score-lbl">{{i_lbl2}}</text>
    </view>
    <view class="score-divider"></view>
    <view class="score-item">
      <text class="score-val">{{timeDisplay}}</text>
      <text class="score-lbl">{{i_lbl3}}</text>
    </view>
  </view>

  <!-- ── Rewards ── -->
  <view class="rewards-card">
    <view class="rewards-head">
      <text class="rewards-title">{{i_rewardsTitle}}</text>
      <text class="rewards-sub">{{i_rewardsSub}}</text>
    </view>
    <view class="rewards-row">
      <view class="reward-bubble">🌱</view>
      <view class="reward-bubble">⭐</view>
      <view class="reward-bubble">🌲</view>
    </view>
  </view>

  <!-- ── Start / Stop button ── -->
  <view class="action-area">
    <view class="main-btn {{sessionActive ? 'btn-stop' : 'btn-start'}}"
          bindtap="onStartStop">
      <text>{{i_btnText}}</text>
    </view>
  </view>

  <!-- ── Offline warning ── -->
  <view class="offline-bar" wx:if="{{!connected}}">
    <text>{{i_offline}}</text>
  </view>

  <!-- ── Floating chat button ── -->
  <view class="chat-fab" bindtap="openChat">
    <text class="chat-fab-icon">💬</text>
  </view>

  <!-- ── Chat popup ── -->
  <view class="chat-mask" wx:if="{{showChat}}" bindtap="closeChat"></view>
  <view class="chat-panel {{showChat ? 'chat-panel-open' : ''}}">
    <view class="chat-header">
      <text class="chat-title">{{i_chatTitle}}</text>
      <view class="chat-close" bindtap="closeChat">✕</view>
    </view>
    <scroll-view class="chat-messages" scroll-y scroll-into-view="{{scrollId}}" scroll-with-animation>
      <view wx:for="{{chatMessages}}" wx:key="id" id="msg{{item.id}}"
            class="chat-msg {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}">
        <text class="msg-text">{{item.text}}</text>
      </view>
      <view wx:if="{{chatLoading}}" class="chat-msg msg-ai">
        <text class="msg-text typing">···</text>
      </view>
    </scroll-view>
    <view class="chat-input-row">
      <input class="chat-input" value="{{chatInput}}"
             bindinput="onChatInput"
             bindconfirm="sendChat"
             placeholder="{{i_chatPlaceholder}}"
             confirm-type="send"
             adjust-position/>
      <view class="chat-send {{chatInput ? 'send-active' : ''}}" bindtap="sendChat">
        <text>↑</text>
      </view>
    </view>
  </view>

</view>
